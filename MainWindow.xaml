<Window x:Class="lab9_RPM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab9_RPM"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <!-- Верхнее меню навигации -->
        <StackPanel DockPanel.Dock="Top" 
                    Orientation="Horizontal" 
                    Background="#2C3E50" 
                    Height="50">

            <Button Content="Контакты" 
                    Command="{Binding ShowContactsCommand}"
                    Margin="5" 
                    Padding="15,5"
                    Background="#3498DB"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="О программе" 
                    Command="{Binding ShowAboutCommand}"
                    Margin="5" 
                    Padding="15,5"
                    Background="#95A5A6"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Область динамического контента -->
        <Border Background="#F5F5F5" Padding="10">
            <ContentControl Content="{Binding NavigationService.CurrentViewModel}" />
        </Border>
    </DockPanel>
</Window>
