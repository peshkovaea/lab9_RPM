<Window x:Class="lab9_RPM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab9_RPM"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Управление контактами" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   HorizontalAlignment="Center"/>

        <!-- Поле ввода имени -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Имя:" 
                       Width="60" 
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300"
                     Margin="10,0,0,0"
                     Padding="5"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Поле ввода телефона -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Телефон:" 
                       Width="60" 
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300"
                     Margin="10,0,0,0"
                     Padding="5"
                     VerticalContentAlignment="Center"/>
            <TextBlock Text="Формат: +7XXXXXXXXXX, 8XXXXXXXXXX или XXXXXXXXXX" 
                       FontSize="10" 
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    Margin="0,15"
                    HorizontalAlignment="Center">
            <Button Content=" Добавить контакт" 
                    Command="{Binding AddCommand}"
                    Width="140" 
                    Height="35"
                    Margin="0,0,15,0"
                    Padding="5"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Удалить контакт" 
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding SelectedContact}"
                    Width="140" 
                    Height="35"
                    Padding="5"
                    Background="#F44336"
                    Foreground="White"
                    FontWeight="Bold"/>
        </StackPanel>

        <!-- Таблица контактов -->
        <GroupBox Grid.Row="4" 
                  Header="Список контактов" 
                  Margin="0,10,0,0"
                  Padding="5">
            <DataGrid ItemsSource="{Binding Contacts}"
                      SelectedItem="{Binding SelectedContact}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      RowHeight="35"
                      Margin="5">

                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2196F3"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#E3F2FD"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Колонка с порядковым номером -->
                    <DataGridTextColumn Header="#" 
                                        Width="50"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0}">
                                <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" 
                                         Path="GetIndex"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <!-- Колонка "Имя" -->
                    <DataGridTextColumn Header="Имя контакта" 
                                        Binding="{Binding Name}"
                                        Width="*"
                                        FontWeight="SemiBold"/>

                    <!-- Колонка "Телефон" -->
                    <DataGridTextColumn Header="Номер телефона" 
                                        Binding="{Binding Phone}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
